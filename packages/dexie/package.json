{
  "name": "@octanejs/dexie",
  "version": "0.1.4",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "octane": {
    "hookSlots": {
      "manual": [
        "src"
      ]
    }
  },
  "description": "Dexie bindings for the octane renderer — reuses Dexie's IndexedDB core and ports dexie-react-hooks onto octane hooks.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/dexie"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "dexie": "catalog:default"
  },
  "peerDependencies": {
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@tsrx/react": "catalog:default",
    "dexie": "catalog:default",
    "dexie-react-hooks": "4.4.0",
    "esbuild": "catalog:default",
    "fake-indexeddb": "catalog:default",
    "octane": "workspace:*",
    "playwright": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "vite": "catalog:default",
    "vitest": "catalog:default"
  }
}
