{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "target": "esnext",
    "jsx": "preserve",
    "jsxImportSource": "octane",
    "noEmit": true,
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": true
  },
  "include": ["./src/"],
  "exclude": ["node_modules", "dist", "tests"]
}
