{
  "name": "vite-plugin-vyre",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Vite metaframework plugin for the vyre renderer (dev SSR + routing + hydrate)",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyre-ts/vyre.git",
    "directory": "packages/vite-plugin-vyre"
  },
  "module": "src/index.js",
  "main": "src/index.js",
  "bin": {
    "vyre-preview": "src/bin/preview.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./production": {
      "types": "./types/production.d.ts",
      "import": "./src/server/production.js",
      "default": "./src/server/production.js"
    }
  },
  "dependencies": {
    "@ripple-ts/adapter": "^0.3.84",
    "vyre": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "type-fest": "^5.6.0",
    "vite": "^8.0.12"
  }
}
