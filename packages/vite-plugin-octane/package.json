{
  "name": "@octanejs/vite-plugin",
  "version": "0.1.10",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "Vite integration for Octane (SPA compilation plus optional routing, SSR, and hydration)",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/vite-plugin-octane"
  },
  "files": [
    "src",
    "types"
  ],
  "module": "src/index.js",
  "main": "src/index.js",
  "bin": {
    "octane-preview": "src/bin/preview.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./production": {
      "types": "./types/production.d.ts",
      "import": "./src/server/production.js",
      "default": "./src/server/production.js"
    },
    "./node": {
      "types": "./types/node.d.ts",
      "import": "./src/server/node-http.js",
      "default": "./src/server/node-http.js"
    }
  },
  "dependencies": {
    "@octanejs/app-core": "workspace:*",
    "@ripple-ts/adapter": "catalog:default"
  },
  "peerDependencies": {
    "octane": "workspace:*",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "catalog:default",
    "octane": "workspace:*",
    "playwright": "catalog:default",
    "type-fest": "catalog:default",
    "vite": "catalog:default"
  }
}
