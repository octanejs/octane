{
  "name": "@octanejs/scan",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "octane": {
    "hookSlots": {
      "manual": [
        "src"
      ]
    }
  },
  "description": "react-scan for the octane renderer — automatic render detection and reporting over octane's profile-build inspection channel. The programmatic core (scan, setOptions, getReport, onRender); outlines and the toolbar land in later phases of docs/octane-scan-port-plan.md.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/scan"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run"
  },
  "peerDependencies": {
    "octane": "workspace:*"
  },
  "devDependencies": {
    "octane": "workspace:*",
    "playwright": "catalog:default",
    "vite": "catalog:default",
    "vitest": "catalog:default"
  }
}
