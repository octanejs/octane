{
  "name": "@octanejs/rspack-plugin",
  "version": "0.1.7",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "Rspack loader and compiler plugin for Octane TSRX source",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/rspack-plugin-octane"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "module": "src/index.js",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./loader": {
      "types": "./types/loader.d.ts",
      "import": "./src/loader.js",
      "default": "./src/loader.js"
    }
  },
  "scripts": {
    "test": "vitest run --config vitest.config.js"
  },
  "dependencies": {
    "@jridgewell/remapping": "catalog:default"
  },
  "peerDependencies": {
    "@rspack/core": "^2.0.0",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "catalog:default",
    "@types/node": "catalog:default",
    "octane": "workspace:*",
    "vitest": "catalog:default"
  }
}
