{
  "name": "@octanejs/rspeedy-plugin",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "description": "Private Milestone 10 dual-thread Rspeedy integration and one-command demo for Octane Lynx.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/rspeedy-plugin-octane"
  },
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "types/index.d.ts",
  "files": [
    "src",
    "types",
    "LICENSE",
    "NOTICE",
    "README.md",
    "UPSTREAM.md"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "demo": "rspeedy dev --root examples/demo",
    "demo:build": "rspeedy build --root examples/demo",
    "demo:typecheck": "tsrx-tsc --noEmit -p examples/demo/tsconfig.json",
    "demo:check": "pnpm demo:typecheck && pnpm demo:build",
    "test": "vitest run --root ../.. --project rspeedy-plugin",
    "test:compat": "node scripts/compatibility-smoke.mjs"
  },
  "dependencies": {
    "@lynx-js/css-extract-webpack-plugin": "catalog:lynx",
    "@lynx-js/runtime-wrapper-webpack-plugin": "catalog:lynx",
    "@lynx-js/template-webpack-plugin": "catalog:lynx",
    "@lynx-js/webpack-dev-transport": "catalog:lynx",
    "@octanejs/lynx": "workspace:*",
    "@octanejs/rspack-plugin": "workspace:*"
  },
  "peerDependencies": {
    "@lynx-js/rspeedy": "0.16.0",
    "@rsbuild/core": "2.1.4",
    "@rspack/core": "2.1.3 || 2.1.5",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/qrcode-rsbuild-plugin": "catalog:lynx",
    "@lynx-js/rspeedy": "catalog:lynx",
    "@lynx-js/tasm": "catalog:lynx",
    "@octanejs/lynx": "workspace:*",
    "@octanejs/rspack-plugin": "workspace:*",
    "@rsbuild/core": "catalog:lynx",
    "@rspack/core": "catalog:lynx",
    "@tsrx/typescript-plugin": "catalog:default",
    "@types/node": "catalog:default",
    "octane": "workspace:*",
    "typescript": "catalog:lynx",
    "vitest": "catalog:default"
  }
}
