{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["esnext", "dom", "dom.iterable"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node"]
  },
  "include": ["src/**/*", "types/**/*", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests/_fixtures"]
}
