    "@types/d3-scale": "catalog:default",
    "@types/d3-shape": "catalog:default",
    "@types/d3-time": "catalog:default",
    "@types/d3-time-format": "catalog:default",
    "@types/d3-voronoi": "catalog:default",
    "@types/geojson": "catalog:default",
    "@types/react": "catalog:default",
    "@use-gesture/core": "catalog:default",
    "classnames": "catalog:default",
    "d3-array": "catalog:default",
    "d3-chord": "catalog:default",
    "d3-cloud": "catalog:default",
    "d3-color": "catalog:default",
    "d3-delaunay": "catalog:default",
    "d3-format": "catalog:default",
    "d3-geo": "catalog:default",
    "d3-hierarchy": "catalog:default",
    "d3-interpolate": "catalog:default",
    "d3-interpolate-path": "catalog:default",
    "d3-path": "catalog:default",
    "d3-random": "catalog:default",
    "d3-sankey": "catalog:default",
    "d3-scale": "catalog:default",
    "d3-shape": "catalog:default",
    "d3-time": "catalog:default",
    "d3-time-format": "catalog:default",
    "d3-voronoi": "catalog:default",
    "internmap": "catalog:default",
    "mitt": "catalog:default",
    "reduce-css-calc": "catalog:default",
    "svg-path-properties": "catalog:default"
  },
  "peerDependencies": {
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@juggle/resize-observer": "catalog:default",
    "@react-spring/web": "catalog:default",
    "@tsrx/react": "catalog:default",
    "@visx/chord": "catalog:default",
    "@visx/annotation": "catalog:default",
    "@visx/brush": "catalog:default",
    "@visx/delaunay": "catalog:default",
    "@visx/react-spring": "catalog:default",
    "@visx/sankey": "catalog:default",
    "@visx/stats": "catalog:default",
    "@visx/tooltip": "catalog:default",
    "@visx/visx": "catalog:default",
    "@visx/xychart": "catalog:default",
    "@visx/zoom": "catalog:default",
    "@vitest/coverage-istanbul": "catalog:default",
    "esbuild": "catalog:default",
    "octane": "workspace:*",
