{
  "name": "@octanejs/visx",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "The complete Airbnb Visx 4 visualization toolkit ported to Octane, with native events and deterministic SSR/hydration.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/visx"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "UPSTREAM.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./a11y": "./src/a11y/index.ts",
    "./a11y/react": "./src/a11y/react/index.ts",
    "./a11y/server": "./src/a11y/server.ts",
    "./annotation": "./src/annotation/index.ts",
    "./axis": "./src/axis/index.ts",
    "./axis/react": "./src/axis/react/index.ts",
    "./bounds": "./src/bounds/index.ts",
    "./brush": "./src/brush/index.ts",
    "./chart": "./src/chart/index.ts",
    "./chord": "./src/chord/index.ts",
    "./clip-path": "./src/clip-path/index.ts",
    "./curve": "./src/curve/index.ts",
    "./delaunay": "./src/delaunay/index.ts",
    "./drag": "./src/drag/index.ts",
    "./event": "./src/event/index.ts",
    "./geo": "./src/geo/index.ts",
    "./glyph": "./src/glyph/index.ts",
    "./gradient": "./src/gradient/index.ts",
    "./grid": "./src/grid/index.ts",
    "./group": "./src/group/index.ts",
    "./heatmap": "./src/heatmap/index.ts",
    "./hierarchy": "./src/hierarchy/index.ts",
    "./kernel": "./src/kernel/index.ts",
    "./legend": "./src/legend/index.ts",
    "./marker": "./src/marker/index.ts",
    "./mock-data": "./src/mock-data/index.ts",
    "./network": "./src/network/index.ts",
    "./pattern": "./src/pattern/index.ts",
    "./point": "./src/point/index.ts",
    "./react-spring": "./src/react-spring/index.ts",
    "./responsive": "./src/responsive/index.ts",
    "./sankey": "./src/sankey/index.ts",
    "./scale": "./src/scale/index.ts",
    "./scale/react": "./src/scale/react/index.ts",
    "./shape": "./src/shape/index.ts",
    "./shape/react": "./src/shape/react/index.ts",
    "./stats": "./src/stats/index.ts",
    "./text": "./src/text/index.ts",
    "./theme": "./src/theme/index.ts",
    "./theme/react": "./src/theme/react/index.ts",
    "./threshold": "./src/threshold/index.ts",
    "./tooltip": "./src/tooltip/index.ts",
    "./tooltip/floating": "./src/tooltip/floating/index.ts",
    "./voronoi": "./src/voronoi/index.ts",
    "./voronoi/react": "./src/voronoi/react/index.ts",
    "./wordcloud": "./src/wordcloud/index.ts",
    "./xychart": "./src/xychart/index.ts",
    "./zoom": "./src/zoom/index.ts"
  },
  "scripts": {
    "compile:check": "node scripts/check-tsrx-compile.mjs",
    "types:generate": "node scripts/generate-tsrx-types.mjs",
    "types:check": "node scripts/generate-tsrx-types.mjs --check && node scripts/check-public-types.mjs",
    "test": "vitest run --root ../.. --project visx --project visx-ssr",
    "test:coverage": "vitest run --root ../.. --project visx --project visx-ssr --coverage.enabled --coverage.provider=istanbul --coverage.include=packages/visx/src/** --coverage.reporter=text --coverage.thresholds.statements=99 --coverage.thresholds.lines=99 --coverage.thresholds.branches=15 --coverage.thresholds.functions=40"
  },
  "dependencies": {
    "@floating-ui/dom": "catalog:default",
    "@octanejs/floating-ui": "workspace:*",
    "@types/d3-array": "catalog:default",
    "@types/d3-chord": "catalog:default",
    "@types/d3-color": "catalog:default",
    "@types/d3-delaunay": "catalog:default",
    "@types/d3-format": "catalog:default",
    "@types/d3-geo": "catalog:default",
    "@types/d3-hierarchy": "catalog:default",
