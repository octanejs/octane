{
  "name": "@octanejs/testing-library",
  "version": "0.1.5",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "octane": {
    "hookSlots": {
      "manual": [
        "src"
      ]
    }
  },
  "description": "React Testing Library for the octane renderer — reuses the framework-agnostic @testing-library/dom verbatim and ports only react-testing-library's thin React layer (render/cleanup/renderHook) onto octane's createRoot + act.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/testing-library"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./pure": "./src/pure.ts"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@testing-library/dom": "catalog:default"
  },
  "peerDependencies": {
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.6.1",
    "octane": "workspace:*",
    "vitest": "catalog:default"
  }
}
