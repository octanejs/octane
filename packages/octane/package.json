{
  "name": "octane",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "description": "A fast, TypeScript-first UI framework and the successor to Inferno: the React API you already know, a compiler that keeps the runtime small and fast, and hooks without the rules of hooks.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/octane"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./constants": "./src/constants.ts",
    "./compiler": "./src/compiler/index.js",
    "./compiler/vite": "./src/compiler/vite.js",
    "./compiler/volar": "./src/compiler/volar.js"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "./constants": {
        "types": "./dist/constants.d.ts",
        "default": "./dist/constants.js"
      },
      "./compiler": "./dist/compiler/index.js",
      "./compiler/vite": "./dist/compiler/vite.js",
      "./compiler/volar": "./dist/compiler/volar.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tsrx/core": "catalog:default",
    "esrap": "catalog:default"
  },
  "devDependencies": {
    "@tsrx/react": "catalog:default",
    "esbuild": "catalog:default",
    "happy-dom": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "vitest": "catalog:default"
  }
}
