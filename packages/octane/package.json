{
  "name": "octane",
  "version": "0.1.12",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "description": "A fast, modern UI framework and the successor to Inferno",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/octane"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./jsx-runtime": "./src/jsx-runtime.d.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.d.ts",
    "./tsrx-iterable": "./src/tsrx-iterable.ts",
    "./tsrx-spread": "./src/tsrx-spread.ts",
    "./react": "./src/react/index.ts",
    "./hydration": "./src/hydration/index.ts",
    "./react/server": "./src/react/server.ts",
    "./server": "./src/server/index.ts",
    "./static": "./src/static/index.ts",
    "./constants": "./src/constants.ts",
    "./profiling": "./src/profiling.ts",
    "./universal": "./src/universal.ts",
    "./universal/native": "./src/universal-native.ts",
    "./compiler": "./src/compiler/index.js",
    "./compiler/bundler": "./src/compiler/bundler.js",
    "./compiler/renderers": "./src/compiler/renderers.js",
    "./compiler/vite": {
      "types": "./src/compiler/vite.d.ts",
      "default": "./src/compiler/vite.js"
    },
    "./compiler/volar": "./src/compiler/volar.js"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "./hydration": {
        "types": "./dist/hydration/index.d.ts",
        "default": "./dist/hydration/index.js"
      },
      "./react/server": {
        "types": "./dist/react/server.d.ts",
        "default": "./dist/react/server.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "./static": {
        "types": "./dist/static/index.d.ts",
        "default": "./dist/static/index.js"
      },
      "./constants": {
        "types": "./dist/constants.d.ts",
        "default": "./dist/constants.js"
      },
      "./profiling": {
        "types": "./dist/profiling.d.ts",
        "default": "./dist/profiling.js"
      },
      "./universal": {
        "types": "./dist/universal.d.ts",
        "default": "./dist/universal.js"
      },
      "./universal/native": {
        "types": "./dist/universal-native.d.ts",
        "default": "./dist/universal-native.js"
      },
      "./compiler": "./dist/compiler/index.js",
      "./compiler/bundler": "./dist/compiler/bundler.js",
      "./compiler/renderers": "./dist/compiler/renderers.js",
      "./compiler/vite": {
        "types": "./dist/compiler/vite.d.ts",
        "default": "./dist/compiler/vite.js"
      },
      "./compiler/volar": "./dist/compiler/volar.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/error-codes/generate.mjs --check && node scripts/build.mjs",
    "prepack": "node ../../scripts/error-codes/generate.mjs --check && node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tsrx/core": "catalog:default",
    "@types/react": "catalog:default",
    "devalue": "catalog:default",
    "esrap": "catalog:default"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.16"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tsrx/react": "catalog:default",
    "esbuild": "catalog:default",
    "happy-dom": "catalog:default",
    "playwright": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "vite": "catalog:default",
    "vitest": "catalog:default"
  }
}
