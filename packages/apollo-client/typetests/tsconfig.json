{
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": false,
    "types": ["node"],
    "noEmit": true,
    "noErrorTruncation": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "react": ["./react-types-must-not-be-imported.d.ts"],
      "react/*": ["./react-types-must-not-be-imported.d.ts"]
    }
  },
  "include": ["./**/*.test-d.ts", "./react-types-must-not-be-imported.d.ts"]
}
