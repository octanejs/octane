{
  "name": "@octanejs/evals",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "Standalone Octane app training tasks, behavioral graders, and reproducible evaluation tooling.",
  "license": "MIT",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/octane-evals"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsonl": {
      "types": "./dist/jsonl.d.ts",
      "import": "./dist/jsonl.js"
    },
    "./dataset": {
      "types": "./dist/dataset.d.ts",
      "import": "./dist/dataset.js"
    },
    "./digest": {
      "types": "./dist/digest.d.ts",
      "import": "./dist/digest.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./reporting": {
      "types": "./dist/reporting.d.ts",
      "import": "./dist/reporting.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "cd ../.. && vitest run --project octane-evals --project octane-evals-user-apps",
    "test:user-apps": "cd ../.. && vitest run --project octane-evals-user-apps",
    "test:user-app-starters": "node scripts/verify-user-app-starters.mjs",
    "grade:user-app": "node scripts/grade-user-app.mjs",
    "corpus:generate": "node scripts/generate-user-app-corpus.mjs",
    "corpus:check": "node scripts/generate-user-app-corpus.mjs --check",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@tsrx/core": "catalog:default",
    "@types/node": "catalog:default",
    "typescript": "catalog:default",
    "vitest": "catalog:default"
  }
}
