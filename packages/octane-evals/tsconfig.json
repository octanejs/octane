{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["esnext"],
    "target": "esnext",
    "noEmit": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "strict": true
  },
  "include": ["./src/"],
  "exclude": ["node_modules", "dist", "tests"]
}
