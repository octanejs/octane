  "dependencies": {
    "@tanstack/pacer": "0.21.1"
  },
  "peerDependencies": {
    "@octanejs/tanstack-store": "workspace:*",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@octanejs/tanstack-store": "workspace:*",
    "octane": "workspace:*",
    "vitest": "catalog:default"
  }
}
