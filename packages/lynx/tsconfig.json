{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["esnext", "webworker"],
    "target": "esnext",
    "noEmit": true,
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": false,
    "types": [],
    "strict": true
  },
  "include": ["./src/"],
  "exclude": ["node_modules", "dist", "tests", "typetests", "src/testing.ts"]
}
