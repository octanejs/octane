{
  "name": "octane-monorepo",
  "private": true,
  "type": "module",
  "author": "Dominic Gannaway",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git"
  },
  "scripts": {
    "test": "vitest run",
    "bench": "pnpm --filter @benchmarks/news bench",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsgo --noEmit -p packages/octane/tsconfig.json && tsgo --noEmit -p packages/vite-plugin-octane/tsconfig.typecheck.json && tsgo --noEmit -p packages/zustand/tsconfig.json && tsgo --noEmit -p packages/query/tsconfig.json && tsgo --noEmit -p packages/motion/tsconfig.json && tsgo --noEmit -p packages/stylex/tsconfig.json && tsgo --noEmit -p packages/router/tsconfig.json && tsgo --noEmit -p packages/lexical/tsconfig.json",
    "changeset": "changeset && pnpm changeset:check",
    "changeset:check": "node scripts/check-changesets.js",
    "changeset:version": "pnpm changeset:check && changeset version",
    "changeset:publish": "pnpm changeset:check && changeset publish",
    "prepare": "rulesync generate || true",
    "rules:generate": "rulesync generate",
    "rules:check": "rulesync generate --check"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:default",
    "@changesets/changelog-git": "catalog:default",
    "@changesets/cli": "catalog:default",
    "@tsrx/prettier-plugin": "catalog:default",
    "@types/node": "catalog:default",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "prettier": "catalog:default",
    "rulesync": "catalog:default",
    "typescript": "catalog:default",
    "vitest": "catalog:default",
    "jsdom": "catalog:default",
    "happy-dom": "catalog:default",
    "esbuild": "catalog:default"
  }
}
