{
  "name": "vyre-monorepo",
  "private": true,
  "type": "module",
  "author": "Dominic Gannaway",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyre-ts/vyre.git"
  },
  "scripts": {
    "test": "vitest run",
    "bench": "pnpm --filter @benchmarks/news bench",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsgo --noEmit -p packages/vyre/tsconfig.json && tsgo --noEmit -p packages/vite-plugin-vyre/tsconfig.typecheck.json",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:default",
    "@changesets/cli": "catalog:default",
    "@tsrx/prettier-plugin": "catalog:default",
    "@types/node": "catalog:default",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "prettier": "catalog:default",
    "typescript": "catalog:default",
    "vitest": "catalog:default",
    "jsdom": "catalog:default",
    "happy-dom": "catalog:default",
    "esbuild": "catalog:default"
  }
}
