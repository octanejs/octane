{
  "name": "flowboard-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A deterministic issue and project board exercising Octane refs, portals, keyed identity, and the @octanejs/dnd-kit binding.",
  "scripts": {
    "dev": "vite --host --port 5220 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host --port 5220 --strictPort",
    "typecheck": "tsrx-tsc --noEmit -p tsconfig.json",
    "test:e2e": "pnpm build && OCTANE_EXAMPLE_PREVIEW=1 playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@octanejs/dnd-kit": "workspace:*",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "catalog:default",
    "@types/node": "catalog:default",
    "typescript": "catalog:default",
    "vite": "catalog:default"
  }
}
