{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "plugins": [{ "name": "@tsrx/typescript-plugin" }]
  },
  "include": ["src/**/*", "e2e/**/*", "env.d.ts", "vite.config.ts"]
}
