{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "octane",
    "types": [
      "node"
    ]
  },
  "include": [
    "shared/**/*",
    "jsx/**/*",
    "tsrx/**/*",
    "e2e/**/*",
    "env.d.ts"
  ]
}
