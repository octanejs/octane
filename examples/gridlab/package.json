{
  "name": "gridlab-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A deterministic virtualized spreadsheet exercising Octane and the @octanejs/tanstack-virtual binding.",
  "scripts": {
    "dev": "vite --host --port 5227 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host --port 5227 --strictPort",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "pnpm build && OCTANE_EXAMPLE_PREVIEW=1 playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@octanejs/tanstack-virtual": "workspace:*",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "catalog:default",
    "@types/node": "catalog:default",
    "typescript": "catalog:default",
    "vite": "catalog:default"
  }
}
