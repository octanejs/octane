{
  "name": "octane-playground",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Playground for octane — the template-clone renderer, compiled through octane-ts/compiler.",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "debug-all": "node ../../scripts/debug-mode.js all octane-ts/compiler",
    "debug-client": "node ../../scripts/debug-mode.js client octane-ts/compiler",
    "debug-ssr": "node ../../scripts/debug-mode.js server octane-ts/compiler",
    "debug-volar": "node ../../scripts/debug-mode.js tsx octane-ts/compiler",
    "debug-tsx": "pnpm run debug-volar"
  },
  "dependencies": {
    "octane-ts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:default",
    "vite": "catalog:default"
  }
}
