{
  "name": "octane-playground",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "description": "Playground for octane — the template-clone renderer, compiled through octane/compiler.",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "debug-all": "node ../../scripts/debug-mode.js all octane/compiler",
    "debug-client": "node ../../scripts/debug-mode.js client octane/compiler",
    "debug-ssr": "node ../../scripts/debug-mode.js server octane/compiler",
    "debug-volar": "node ../../scripts/debug-mode.js tsx octane/compiler",
    "debug-tsx": "pnpm run debug-volar"
  },
  "dependencies": {
    "@octanejs/cmdk": "workspace:*",
    "octane": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:default",
    "vite": "catalog:default"
  }
}
